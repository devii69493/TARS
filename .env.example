# Copy this file to .env.local and fill in your keys.
# For local dev with Netlify Functions (Notion proxy), run: netlify dev

# ── AI backend ─────────────────────────────────────────────────────────────
# Anthropic (current) — https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Optional providers (switch in src/lib/aiConfig.js)
# VITE_GROQ_API_KEY=gsk_...
# VITE_GEMINI_API_KEY=AIza...
# VITE_OPENROUTER_API_KEY=sk-or-v1-...

# Optional — only needed if switching providers in src/lib/aiConfig.js
# VITE_GEMINI_API_KEY=AIza...
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# ── ElevenLabs TTS (optional) ───────────────────────────────────────────────
# Falls back to Web Speech Synthesis if missing. Toggle in src/hooks/useTTS.js
# Get a key at https://elevenlabs.io — free tier works fine
VITE_ELEVENLABS_API_KEY=sk_...
# Voice ID from https://elevenlabs.io/voice-library or your cloned voices
VITE_ELEVENLABS_VOICE_ID=...

# ── Google (Gmail + Calendar) ───────────────────────────────────────────────
# 1. Create a project at https://console.cloud.google.com
# 2. Enable Gmail API and Google Calendar API
# 3. Create OAuth 2.0 credentials → Web Application
#    Authorised origins: http://localhost:5173, https://tarsdev.netlify.app
# 4. Paste the Client ID below (it's public — safe as VITE_ prefix)
VITE_GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com

# ── Notion ──────────────────────────────────────────────────────────────────
# 1. Go to https://www.notion.so/my-integrations and create an integration
# 2. Share the pages/databases you want TARS to access with the integration
# 3. Set NOTION_API_KEY in Netlify environment variables dashboard (server-side only)
NOTION_API_KEY=secret_...

# ── Web Search (Tavily) ─────────────────────────────────────────────────────
# Get a free key at https://tavily.com
# Client-side key used for local dev; in production set TAVILY_API_KEY (no VITE_ prefix) in Netlify
VITE_TAVILY_API_KEY=tvly-...

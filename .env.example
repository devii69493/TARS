# Copy this file to .env.local and fill in your keys.
# For local dev with Netlify Functions (Notion proxy), run: netlify dev

# ── AI backend ─────────────────────────────────────────────────────────────
# Groq (default) — https://console.groq.com
VITE_GROQ_API_KEY=gsk_...

# Optional — only needed if switching providers in src/lib/aiConfig.js
# VITE_GEMINI_API_KEY=AIza...
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# ── Google (Gmail + Calendar) ───────────────────────────────────────────────
# 1. Create a project at https://console.cloud.google.com
# 2. Enable Gmail API and Google Calendar API
# 3. Create OAuth 2.0 credentials → Web Application
#    Authorised origins: http://localhost:5173, https://tarsdev.netlify.app
# 4. Paste the Client ID below (it's public — safe as VITE_ prefix)
VITE_GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com

# ── Notion ──────────────────────────────────────────────────────────────────
# 1. Go to https://www.notion.so/my-integrations and create an integration
# 2. Share the pages/databases you want TARS to access with the integration
# 3. Set NOTION_API_KEY in Netlify environment variables dashboard (NOT .env.local if using netlify dev)
#    OR set it here for local dev with netlify dev:
NOTION_API_KEY=secret_...
